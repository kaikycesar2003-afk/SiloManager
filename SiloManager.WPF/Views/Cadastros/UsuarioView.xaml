<UserControl x:Class="SiloManager.WPF.Views.Cadastros.UsuarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F5F0E8">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título + Toggle -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="👥 Usuários"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <RadioButton Content="Ativos"
                             IsChecked="{Binding MostrarInativos,
                                Converter={StaticResource InverseBoolToVisibilityConverter},
                                Mode=OneWay}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"/>
                <RadioButton Content="Todos"
                             IsChecked="{Binding MostrarInativos}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"/>
            </StackPanel>
        </Grid>

        <!-- Formulário -->
        <Border Grid.Row="1" Background="White" CornerRadius="8"
                Padding="24" Margin="0,0,0,16"
                Effect="{StaticResource MaterialDesignShadowDepth1}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*" MinWidth="140"/>
                    <ColumnDefinition Width="*" MinWidth="140"/>
                    <ColumnDefinition Width="*" MinWidth="140"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Linha 1 -->
                <TextBox Grid.Row="0" Grid.Column="0"
                         Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Nome completo"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,12,12"/>

                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Login"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,12,12"/>

                <PasswordBox Grid.Row="0" Grid.Column="2"
                             x:Name="SenhaBox"
                             md:HintAssist.Hint="Senha"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,12,12"/>

                <ComboBox Grid.Row="0" Grid.Column="3"
                          ItemsSource="{Binding NiveisAcesso}"
                          SelectedItem="{Binding NivelSelecionado}"
                          md:HintAssist.Hint="Nível de Acesso"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,12,12"/>

                <!-- Linha 2 — Alterar senha (só edição) -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            Visibility="{Binding IsEdicao, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <md:PackIcon Kind="Information" Foreground="Gray"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Deixe a senha em branco para não alterar."
                               Foreground="Gray" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="4"
                        Click="BtnSalvar_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="56" Width="56" Padding="0"
                        VerticalAlignment="Top" ToolTip="Salvar">
                    <md:PackIcon Kind="ContentSave" Width="24" Height="24"/>
                </Button>
            </Grid>
        </Border>

        <!-- Lista -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                Effect="{StaticResource MaterialDesignShadowDepth1}">
            <DataGrid ItemsSource="{Binding Usuarios}"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="True" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" Background="Transparent"
                      BorderThickness="0">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Ativo}" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome"   Binding="{Binding Nome}"        Width="2*"/>
                    <DataGridTextColumn Header="Login"  Binding="{Binding Login}"       Width="*"/>
                    <DataGridTextColumn Header="Nível"  Binding="{Binding Nivel}"       Width="*"/>
                    <DataGridTemplateColumn Header="Ações" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.EditarUsuarioCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}" ToolTip="Editar"
                                            Visibility="{Binding Ativo, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <md:PackIcon Kind="Pencil"/>
                                    </Button>
                                    <Button Command="{Binding DataContext.DesativarUsuarioCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Foreground="Red" ToolTip="Desativar"
                                            Visibility="{Binding Ativo, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <md:PackIcon Kind="Delete"/>
                                    </Button>
                                    <Button Command="{Binding DataContext.ReativarUsuarioCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Foreground="Green" ToolTip="Reativar"
                                            Visibility="{Binding Ativo, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <md:PackIcon Kind="Restore"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>