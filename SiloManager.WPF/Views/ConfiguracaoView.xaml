<UserControl x:Class="SiloManager.WPF.Views.ConfiguracaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F5F0E8">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="⚙ Configurações"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,24"/>

        <!-- Timer -->
        <Border Grid.Row="1" Background="White" CornerRadius="8"
                Padding="24" Margin="0,0,0,16"
                Effect="{StaticResource MaterialDesignShadowDepth1}">
            <StackPanel>

                <TextBlock Text="TIMER DE MEDIÇÃO"
                           FontSize="11" FontWeight="Bold"
                           Opacity="0.5" Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Minutos -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Intervalo mínimo (minutos)"
                                   FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding IntervaloMinutos, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="Ex: 15"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>

                    <!-- Preview -->
                    <StackPanel Grid.Column="1" Margin="0,0,12,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Equivale a"
                                   FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{Binding PreviewTimer}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    </StackPanel>

                    <!-- Info -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Configuração atual"
                                   FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{Binding ConfiguracaoAtual}"
                                   FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Command="{Binding SalvarCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="56" Width="56" Padding="0"
                            VerticalAlignment="Bottom" ToolTip="Salvar">
                        <md:PackIcon Kind="ContentSave" Width="24" Height="24"/>
                    </Button>
                </Grid>

                <!-- Slider visual -->
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="Ajuste rápido" FontSize="12" Opacity="0.6" Margin="0,0,0,8"/>
                    <Slider Minimum="1" Maximum="60"
                            Value="{Binding IntervaloMinutos}"
                            TickFrequency="5"
                            IsSnapToTickEnabled="False"/>
                    <Grid>
                        <TextBlock Text="1 min" FontSize="11" Opacity="0.5"/>
                        <TextBlock Text="30 min" FontSize="11" Opacity="0.5"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="60 min" FontSize="11" Opacity="0.5"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Info -->
        <Border Grid.Row="2" Background="#E8F5E9" CornerRadius="8"
                Padding="16" BorderBrush="#A5D6A7" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="Information" Foreground="#2E7D32"
                             Width="20" Height="20" Margin="0,0,10,0"
                             VerticalAlignment="Center"/>
                <TextBlock TextWrapping="Wrap" Foreground="#2E7D32" FontSize="13">
                    O timer define o intervalo mínimo entre medições.<LineBreak/>
                    Com 15 minutos configurado, após cada medição o operador deve aguardar 15 minutos antes de realizar a próxima.
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>