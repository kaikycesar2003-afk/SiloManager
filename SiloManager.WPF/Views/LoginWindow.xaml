<Window x:Class="SiloManager.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Seedry — Login"
        Height="560" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Background="#F5F0E8">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <StackPanel Margin="40" VerticalAlignment="Center">

        <!-- Logo / Título -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
            <md:PackIcon Kind="Grain" Width="56" Height="56"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Seedry"
                       Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
            <TextBlock Text="Gestão de Umidade em Silos"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       HorizontalAlignment="Center" Opacity="0.6"/>
        </StackPanel>

        <!-- Empresa -->
        <ComboBox ItemsSource="{Binding Empresas}"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding EmpresaIdSelecionada}"
                  DisplayMemberPath="Nome"
                  md:HintAssist.Hint="Empresa"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  Margin="0,0,0,16"/>

        <!-- Login -->
        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                 md:HintAssist.Hint="Usuário"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- Senha -->
        <PasswordBox x:Name="SenhaBox"
                     md:HintAssist.Hint="Senha"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     Margin="0,0,0,8"/>

        <!-- Erro -->
        <TextBlock Text="{Binding Erro}"
                   Foreground="Red"
                   FontSize="12"
                   Margin="0,0,0,12"
                   TextWrapping="Wrap"/>

        <!-- Botão Entrar -->
        <Button Click="BtnEntrar_Click"
                Content="ENTRAR"
                Style="{StaticResource MaterialDesignRaisedButton}"
                IsDefault="True"
                HorizontalAlignment="Stretch"
                Height="44"/>

        <!-- Loading -->
        <ProgressBar IsIndeterminate="True"
                     Visibility="{Binding Carregando, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Margin="0,16,0,0"/>

    </StackPanel>
</Window>