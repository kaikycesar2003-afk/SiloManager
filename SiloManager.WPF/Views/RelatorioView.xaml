<UserControl x:Class="SiloManager.WPF.Views.RelatorioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F5F0E8">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="📋 Relatórios"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16"/>

        <!-- Filtros -->
        <Border Grid.Row="1" Background="White" CornerRadius="8"
                Padding="20" Margin="0,0,0,12"
                Effect="{StaticResource MaterialDesignShadowDepth1}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DatePicker Grid.Column="0"
                            SelectedDate="{Binding DataInicio}"
                            md:HintAssist.Hint="Data Início"
                            Margin="0,0,12,0"/>

                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding DataFim}"
                            md:HintAssist.Hint="Data Fim"
                            Margin="0,0,12,0"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Produtos}"
                          SelectedItem="{Binding ProdutoFiltro}"
                          DisplayMemberPath="Nome"
                          md:HintAssist.Hint="Produto (todos)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,12,0"/>

                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding Silos}"
                          SelectedItem="{Binding SiloFiltro}"
                          DisplayMemberPath="Nome"
                          md:HintAssist.Hint="Silo (todos)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,12,0"/>

                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding Usuarios}"
                          SelectedItem="{Binding UsuarioFiltro}"
                          DisplayMemberPath="Nome"
                          md:HintAssist.Hint="Operador (todos)"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,12,0"/>

                <Button Grid.Column="5"
                        Command="{Binding BuscarCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="56" Width="56" Padding="0" ToolTip="Buscar">
                    <md:PackIcon Kind="Magnify" Width="24" Height="24"/>
                </Button>
            </Grid>
        </Border>

        <!-- Resumo + Exportação -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                Padding="16" Margin="0,0,0,12"
                Effect="{StaticResource MaterialDesignShadowDepth1}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Totalizadores -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <TextBlock Text="TOTAL" FontSize="10" Opacity="0.5" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalMedicoes}" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,24,0">
                    <TextBlock Text="IDEAIS" FontSize="10" Opacity="0.5" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalIdeais}" FontSize="22" FontWeight="Bold"
                               Foreground="#2E7D32"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,24,0">
                    <TextBlock Text="ATENÇÃO" FontSize="10" Opacity="0.5" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalAtencao}" FontSize="22" FontWeight="Bold"
                               Foreground="#E65100"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,24,0">
                    <TextBlock Text="RETRABALHO" FontSize="10" Opacity="0.5" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalRetrabalho}" FontSize="22" FontWeight="Bold"
                               Foreground="#C62828"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,24,0">
                    <TextBlock Text="MÉDIA ENTRE MEDIÇÕES" FontSize="10" Opacity="0.5" FontWeight="Bold"/>
                    <TextBlock Text="{Binding MediaIntervalo}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Exportação -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Command="{Binding ExportarExcelCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="40" Margin="0,0,8,0"
                            BorderBrush="#2E7D32" Foreground="#2E7D32">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FileExcel" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="Excel"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ExportarPdfCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="40"
                            BorderBrush="#C62828" Foreground="#C62828">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FilePdfBox" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="PDF"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabela -->
        <Border Grid.Row="3" Background="White" CornerRadius="8"
                Effect="{StaticResource MaterialDesignShadowDepth1}">
            <DataGrid ItemsSource="{Binding Linhas}"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="True" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" Background="Transparent"
                      BorderThickness="0">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRetrabalho}" Value="True">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data/Hora"
                                        Binding="{Binding DataHora, StringFormat={}{0:dd/MM/yy HH:mm}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Operador"    Binding="{Binding Operador}"    Width="*"/>
                    <DataGridTextColumn Header="Produto"     Binding="{Binding Produto}"     Width="*"/>
                    <DataGridTextColumn Header="Umidade"
                                        Binding="{Binding Umidade, StringFormat={}{0:F1}%}"
                                        Width="80"/>
                    <DataGridTemplateColumn Header="Status" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Ideal">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Seco">
                                                    <Setter Property="Foreground" Value="#F57F17"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Atenção">
                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Crítico">
                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Equipamento" Binding="{Binding Equipamento}"  Width="*"/>
                    <DataGridTextColumn Header="Silo Destino" Binding="{Binding SiloDestino}" Width="*"/>
                    <DataGridTextColumn Header="Intervalo"   Binding="{Binding Intervalo}"   Width="80"/>
                    <DataGridTextColumn Header="Observação"  Binding="{Binding Observacao}"  Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>