<Window x:Class="SiloManager.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Seedry"
        Height="680" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ TOPBAR ═══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <md:PackIcon Kind="Grain" Width="28" Height="28" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="Seedry" Foreground="White"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Empresa logada -->
                <TextBlock Grid.Column="1"
                           Text="{Binding NomeEmpresa}"
                           Foreground="White" Opacity="0.8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>

                <!-- Usuário + Sair -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <md:PackIcon Kind="Account" Width="20" Height="20" Foreground="White" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding NomeUsuario}" Foreground="White"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="SAIR"
                            Command="{Binding SairCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="White" Foreground="White"
                            Height="32" Padding="12,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MENU LATERAL ═══ -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#EDEAE0"
                BorderBrush="#D5D0C5" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,8,0,8">

                    <!-- Medição -->
                    <Button Content="  📊  Medição"
                            Command="{Binding NavCommand}" CommandParameter="Medicao"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch" Height="48"
                            Foreground="#2E7D32" FontSize="14"/>

                    <!-- Relatórios -->
                    <Button Content="  📋  Relatórios"
                            Command="{Binding NavCommand}" CommandParameter="Relatorio"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch" Height="48"
                            Foreground="#2E7D32" FontSize="14"/>

                    <Separator Margin="16,8"/>

                    <!-- Cadastros — só Admin/Gerente -->
                    <TextBlock Text="CADASTROS" Margin="16,4,0,4"
                               FontSize="11" Opacity="0.5" FontWeight="Bold"
                               Visibility="{Binding IsAdminOuGerente, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="  🌾  Produtos"
                            Command="{Binding NavCommand}" CommandParameter="Produto"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch" Height="44"
                            Foreground="#388E3C" FontSize="13"
                            Visibility="{Binding IsAdminOuGerente, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="  🏗  Silos"
                            Command="{Binding NavCommand}" CommandParameter="Silo"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch" Height="44"
                            Foreground="#388E3C" FontSize="13"
                            Visibility="{Binding IsAdminOuGerente, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="  📡  Equipamentos"
                            Command="{Binding NavCommand}" CommandParameter="Equipamento"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch" Height="44"
                            Foreground="#388E3C" FontSize="13"
                            Visibility="{Binding IsAdminOuGerente, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="  👥  Usuários"
                            Command="{Binding NavCommand}" CommandParameter="Usuario"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch" Height="44"
                            Foreground="#388E3C" FontSize="13"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="  🏢  Empresas"
                            Command="{Binding NavCommand}" CommandParameter="Empresa"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch" Height="44"
                            Foreground="#388E3C" FontSize="13"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Separator Margin="16,8"
                               Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="  ⚙  Configurações"
                            Command="{Binding NavCommand}" CommandParameter="Configuracao"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch" Height="44"
                            Foreground="#388E3C" FontSize="13"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══ CONTEÚDO PRINCIPAL ═══ -->
        <Border Grid.Row="1" Grid.Column="1" Padding="24">
            <ContentControl Content="{Binding PaginaAtual}"/>
        </Border>

    </Grid>
</Window>