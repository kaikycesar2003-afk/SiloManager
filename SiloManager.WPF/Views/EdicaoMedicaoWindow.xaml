<Window x:Class="SiloManager.WPF.Views.EdicaoMedicaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Editar Medição"
        Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F0E8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="24,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <md:PackIcon Kind="Pencil" Width="22" Height="22"
                             Foreground="White" Margin="0,0,10,0"/>
                <TextBlock Text="Editar Medição"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══ Formulário ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">

                <!-- Umidade -->
                <Border Background="White" CornerRadius="8" Padding="16"
                        Margin="0,0,0,12"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <TextBlock Text="UMIDADE (%)" FontSize="10"
                                   FontWeight="Bold" Opacity="0.5" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtUmidade"
                                 md:HintAssist.Hint="Ex: 12.5"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="24" FontWeight="Bold"
                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    </StackPanel>
                </Border>

                <!-- Produto + Secador -->
                <Border Background="White" CornerRadius="8" Padding="16"
                        Margin="0,0,0,12"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <TextBlock Text="GRÃO E SECADOR" FontSize="10"
                                   FontWeight="Bold" Opacity="0.5" Margin="0,0,0,12"/>
                        <ComboBox x:Name="CboProduto"
                                  md:HintAssist.Hint="Produto"
                                  DisplayMemberPath="Nome"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,0,12"/>
                        <ComboBox x:Name="CboSecador"
                                  md:HintAssist.Hint="Secador (opcional)"
                                  DisplayMemberPath="Nome"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                </Border>

                <!-- Silo Destino -->
                <Border Background="White" CornerRadius="8" Padding="16"
                        Margin="0,0,0,12"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <TextBlock Text="DESTINO" FontSize="10"
                                   FontWeight="Bold" Opacity="0.5" Margin="0,0,0,12"/>
                        <ComboBox x:Name="CboSilo"
                                  md:HintAssist.Hint="Silo Destino"
                                  DisplayMemberPath="Nome"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                </Border>

                <!-- Observação -->
                <Border Background="White" CornerRadius="8" Padding="16"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <TextBlock Text="OBSERVAÇÃO" FontSize="10"
                                   FontWeight="Bold" Opacity="0.5" Margin="0,0,0,12"/>
                        <TextBox x:Name="TxtObservacao"
                                 md:HintAssist.Hint="Opcional..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 AcceptsReturn="True" Height="60"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Botões ═══ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="24,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="CANCELAR"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="42" Margin="0,0,8,0"
                        Click="BtnCancelar_Click"/>

                <Button Grid.Column="1"
                        Content="SALVAR ALTERAÇÕES"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="42" Margin="8,0,0,0"
                        Click="BtnSalvar_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>